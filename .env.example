# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-or-service-key-here

# HuggingFace
HF_API_TOKEN=hf_your-token

# NewsAPI
NEWSAPI_KEY=your-newsapi-key

# OpenCage
OPENCAGE_KEY=your-opencage-key

# ACLED (optional - add later)
ACLED_KEY=your-acled-key

# ── Upstash Redis (Stage 2) ────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io   
UPSTASH_REDIS_REST_TOKEN=your-upstash-token         

# ── Pipeline settings ──────────────────────────────────
PIPELINE_INTERVAL_MINUTES=15
LOG_LEVEL=INFO

# ── API settings (Stage 2) ─────────────────────────────
DEBUG=false                                         
ALLOWED_ORIGINS=*                                   